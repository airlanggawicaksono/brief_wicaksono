# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=wpp
DB_PASSWORD=wpp_dev_password
DB_NAME=wpp_db
DB_HOST=postgres-db
DB_PORT=5432
POSTGRES_EXTERNAL_PORT=5491

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6399

# ── Backend ──────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
BACKEND_EXTERNAL_PORT=8037

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8037
FRONTEND_EXTERNAL_PORT=3071
NODE_ENV=development

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini-2025-04-14
